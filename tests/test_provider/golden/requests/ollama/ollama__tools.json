{
  "auth_style": "none",
  "body": {
    "messages": [
      {
        "content": "You are a synthetic assistant used to freeze provider request payloads.",
        "role": "system"
      },
      {
        "content": "List the files in the workspace root.",
        "role": "user"
      },
      {
        "content": "I will list the files.",
        "role": "assistant",
        "tool_calls": [
          {
            "function": {
              "arguments": {
                "max_entries": 3,
                "path": "."
              },
              "name": "list_files"
            }
          }
        ]
      },
      {
        "content": "README.md\nsrc\ntests",
        "role": "tool",
        "tool_name": "list_files"
      }
    ],
    "model": "llama3",
    "options": {
      "num_ctx": 8192,
      "num_predict": 16384,
      "temperature": 0.7
    },
    "stream": true,
    "tools": [
      {
        "function": {
          "description": "List files under a workspace-relative path.",
          "name": "list_files",
          "parameters": {
            "properties": {
              "filters": {
                "default": [],
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "maxItems": 5,
                "minItems": 1,
                "type": "array"
              },
              "max_entries": {
                "maximum": 50,
                "minimum": 1,
                "type": "integer"
              },
              "options": {
                "additionalProperties": false,
                "properties": {
                  "include_hidden": {
                    "default": false,
                    "type": "boolean"
                  }
                },
                "type": "object"
              },
              "path": {
                "default": ".",
                "description": "Workspace-relative directory to list.",
                "maxLength": 200,
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "path"
            ],
            "type": "object"
          }
        },
        "type": "function"
      }
    ]
  },
  "content_type": "application/json",
  "method": "POST",
  "url": "http://localhost:11434/api/chat"
}
